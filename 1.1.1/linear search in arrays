#include <stdio.h>
int main () {
	int n, key, found = 0;
	if (scanf("%d", &n) != 1) return 0;
	int arr[n];
	for (int i=0; i<n; i++) {
		scanf("%d", &arr[i]);
	}
	scanf("%d", &key);
	for (int i=0; i<n; i++) {
		if (arr[i] == key) {
			printf("found at position %d\n", i);
			found = 1;
			break;
		}
	}
	if (!found) {
		printf("%d not found\n", key);
	}
	return 0;
}
